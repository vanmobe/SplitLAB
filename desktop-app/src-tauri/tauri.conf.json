{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AudioLab Splitter",
  "version": "0.1.0",
  "identifier": "com.vanmobe.audiolab.splitter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AudioLab Splitter",
        "width": 920,
        "height": 1220,
        "minWidth": 680,
        "minHeight": 1080,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
